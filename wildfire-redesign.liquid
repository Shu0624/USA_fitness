<!--
  Shopify Section: USA Supplement — Complete Redesign
  Agency: GrowWithUs
  File: sections/wildfire-redesign.liquid
  Version: 2.0
  Deploy: Shopify OS 2.0 Theme → Sections → Add New Section → Paste
-->

{%- style -%}
  /* ════════════════════════════════════════════════════════════════
     USA SUPPLEMENT — PREMIUM DESIGN SYSTEM
     Warm Brown / Cream / Gold Palette
     ════════════════════════════════════════════════════════════════ */

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
  @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css');

  :root {
    --usa-bg-dark: {{ section.settings.bg_dark | default: '#1a1108' }};
    --usa-bg-cream: {{ section.settings.bg_cream | default: '#f7f2ea' }};
    --usa-bg-cream-alt: {{ section.settings.bg_cream_alt | default: '#efe8db' }};
    --usa-accent: {{ section.settings.accent_color | default: '#c8860a' }};
    --usa-accent-hover: {{ section.settings.accent_color | default: '#c8860a' | color_lighten: 8 }};
    --usa-accent-glow: {{ section.settings.accent_color | default: '#c8860a' | color_modify: 'alpha', 0.2 }};
    --usa-accent-soft: {{ section.settings.accent_color | default: '#c8860a' | color_modify: 'alpha', 0.08 }};
    --usa-text-dark: #2c1810;
    --usa-text-light: #f7f2ea;
    --usa-text-muted-dark: #8a7560;
    --usa-text-muted-light: #a09080;
    --usa-border-dark: rgba(255,255,255,0.08);
    --usa-border-light: rgba(44,24,16,0.1);
    --usa-card-dark: rgba(255,255,255,0.04);
    --usa-card-light: rgba(255,255,255,0.7);
    --usa-green: #52c41a;
    --usa-red: #f5222d;
    --usa-font-display: 'Inter', sans-serif;
    --usa-font-body: 'Inter', sans-serif;
    --usa-shadow-soft: 0 10px 40px rgba(0,0,0,0.03);
    --usa-shadow-hover: 0 15px 50px rgba(0,0,0,0.06);
  }

  /* ── RESET & BASE ── */
  .usa-wrapper {
    font-family: var(--usa-font-body);
    line-height: 1.65;
    overflow-x: hidden;
    color: var(--usa-text-dark);
    -webkit-font-smoothing: antialiased;
  }
  .usa-wrapper *, .usa-wrapper *::before, .usa-wrapper *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  .usa-wrapper img { max-width: 100%; display: block; }
  .usa-wrapper a { color: inherit; text-decoration: none; }
  .usa-wrapper ul { list-style: none; }

  .usa-wrapper .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── SHARED COMPONENTS ── */
  .usa-wrapper .section-tag {
    display: inline-block;
    font-family: var(--usa-font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--usa-accent);
    margin-bottom: 16px;
  }

  .usa-wrapper .section-head {
    text-align: center;
    margin-bottom: 80px;
  }
  .usa-wrapper .section-head h2 {
    font-family: var(--usa-font-display);
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .usa-wrapper .section-head p {
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .usa-wrapper .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--usa-font-body);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
    padding: 16px 36px;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: all 0.3s var(--usa-ease);
    text-decoration: none;
  }
  .usa-wrapper .btn-primary {
    background: var(--usa-accent);
    color: #fff;
  }
  .usa-wrapper .btn-primary:hover {
    transform: translateY(-2px);
    background: var(--usa-accent-hover);
    box-shadow: var(--usa-shadow-soft);
  }
  .usa-wrapper .btn-outline-dark {
    background: transparent;
    color: var(--usa-text-dark);
    border: 1.5px solid var(--usa-border-light);
  }
  .usa-wrapper .btn-outline-dark:hover {
    border-color: var(--usa-accent);
    color: var(--usa-accent);
    transform: translateY(-3px);
  }
  .usa-wrapper .btn-outline-light {
    background: transparent;
    color: var(--usa-text-light);
    border: 1px solid var(--usa-border-dark);
  }
  .usa-wrapper .btn-outline-light:hover {
    border-color: #fff;
    color: #fff;
    transform: translateY(-2px);
  }
  .usa-wrapper .btn-dark {
    background: var(--usa-bg-dark);
    color: var(--usa-text-light);
  }
  .usa-wrapper .btn-dark:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .usa-wrapper .btn-wide { width: 100%; }

  /* GSAP Handles scroll reveal animations. No CSS required here to prevent conflicts. */

  /* ════════════════════════════════════════════════
     SECTION STYLES
     ════════════════════════════════════════════════ */

  /* ── MARQUEE ── */
  .usa-wrapper .marquee-bar {
    background: var(--usa-bg-dark);
    padding: 10px 0;
    overflow: hidden;
    white-space: nowrap;
    font-family: var(--usa-font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    color: var(--usa-text-muted-light);
    text-transform: uppercase;
  }
  .usa-wrapper .marquee-track {
    display: inline-block;
    animation: usaMarquee 40s linear infinite;
  }
  .usa-wrapper .marquee-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--usa-accent);
    border-radius: 50%;
    margin: 0 28px;
    vertical-align: middle;
  }
  @keyframes usaMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── HERO ── */
  .usa-wrapper .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--usa-bg-dark);
  }
  .usa-wrapper .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }
  .usa-wrapper .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(135deg, rgba(26,17,8,0.85) 0%, rgba(26,17,8,0.5) 50%, rgba(26,17,8,0.9) 100%);
  }
  .usa-wrapper .hero-content {
    position: relative;
    z-index: 3;
    max-width: 700px;
    padding: 0 40px;
    margin-left: max(40px, calc((100% - 1200px)/2 + 24px));
  }
  .usa-wrapper .hero-badge {
    display: inline-block;
    font-family: var(--usa-font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--usa-accent);
    background: var(--usa-accent-soft);
    border: 1px solid rgba(200,134,10,0.2);
    padding: 8px 18px;
    border-radius: 100px;
    margin-bottom: 28px;
  }
  .usa-wrapper .hero-section h1 {
    font-family: var(--usa-font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -2px;
    color: var(--usa-text-light);
    margin-bottom: 24px;
  }
  .usa-wrapper .hero-section h1 em {
    color: var(--usa-accent);
    font-style: italic;
  }
  .usa-wrapper .hero-sub {
    color: var(--usa-text-muted-light);
    font-size: 1.15rem;
    line-height: 1.75;
    margin-bottom: 40px;
    max-width: 540px;
  }
  .usa-wrapper .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .usa-wrapper .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--usa-text-muted-light);
    font-family: var(--usa-font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .usa-wrapper .scroll-pill {
    width: 20px; height: 32px;
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 12px;
    position: relative;
  }
  .usa-wrapper .scroll-dot-anim {
    width: 3px; height: 6px;
    background: var(--usa-accent);
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: usaBobble 1.6s ease-in-out infinite;
  }
  @keyframes usaBobble {
    0%,100% { opacity: 0; top: 6px; }
    40% { opacity: 1; }
    80% { opacity: 0; top: 18px; }
  }

  /* ── VISION & MISSION ── */
  .usa-wrapper .vision-section {
    padding: 120px 0;
    background: var(--usa-bg-cream);
  }
  .usa-wrapper .vision-section .section-head p {
    color: var(--usa-text-muted-dark);
  }
  .usa-wrapper .vm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 80px;
  }
  .usa-wrapper .vm-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 48px;
    text-align: center;
    box-shadow: var(--usa-shadow-soft);
    border: 1px solid rgba(0,0,0,0.03);
    transition: box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .usa-wrapper .vm-card:hover {
    box-shadow: var(--usa-shadow-hover);
  }
  .usa-wrapper .vm-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--usa-accent), transparent);
  }
  .usa-wrapper .vm-icon {
    width: 64px; height: 64px;
    border-radius: 16px;
    background: var(--usa-accent-soft);
    border: 1px solid rgba(200,134,10,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--usa-accent);
    margin-bottom: 28px;
  }
  .usa-wrapper .vm-card h3 {
    font-family: var(--usa-font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--usa-text-dark);
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }
  .usa-wrapper .vm-card p {
    color: var(--usa-text-muted-dark);
    font-size: 1rem;
    line-height: 1.75;
  }

  /* Ecosystem Pillars */
  .usa-wrapper .pillars-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }
  .usa-wrapper .pillar-tile {
    background: transparent;
    border-radius: 12px;
    padding: 32px 24px;
    text-align: center;
    border: 1px solid rgba(0,0,0,0.05);
    transition: all 0.4s ease;
  }
  .usa-wrapper .pillar-tile:hover {
    background: #ffffff;
    transform: translateY(-5px);
    box-shadow: var(--usa-shadow-soft);
    border-color: transparent;
  }
  .usa-wrapper .pillar-icon {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--usa-accent-soft);
    border: 1.5px solid rgba(200,134,10,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: var(--usa-accent);
    margin: 0 auto 16px;
    transition: all 0.3s;
  }
  .usa-wrapper .pillar-tile:hover .pillar-icon {
    background: var(--usa-accent);
    color: #fff;
    transform: scale(1.1);
  }
  .usa-wrapper .pillar-tile h4 {
    font-family: var(--usa-font-display);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--usa-text-dark);
    letter-spacing: 0.3px;
  }

  /* ── PRODUCTS ── */
  .usa-wrapper .products-section {
    padding: 120px 0;
    background: var(--usa-bg-dark);
    color: var(--usa-text-light);
  }
  .usa-wrapper .products-section .section-head h2,
  .usa-wrapper .products-section .section-tag {
    color: var(--usa-text-light);
  }
  .usa-wrapper .products-section .section-head p {
    color: var(--usa-text-muted-light);
  }
  .usa-wrapper .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .usa-wrapper .product-card {
    background: rgba(255,255,255,0.02);
    border-radius: 12px;
    padding: 24px;
    border: 1px solid var(--usa-border-dark);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
  }
  .usa-wrapper .product-card:hover {
    background: rgba(255,255,255,0.04);
    transform: translateY(-5px);
  }
  .usa-wrapper .product-card-img {
    width: 100%; height: 320px;
    background: var(--usa-bg-cream);
    border-radius: 12px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .usa-wrapper .product-card-img img {
    width: 80%; height: auto;
    object-fit: contain;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .usa-wrapper .product-card:hover .product-card-img img {
    transform: scale(1.08);
  }
  .usa-wrapper .product-card-badge {
    position: absolute;
    top: 16px; left: 16px;
    font-family: var(--usa-font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 6px;
    z-index: 2;
  }
  .usa-wrapper .badge-bestseller { background: #e04a19; color: #fff; }
  .usa-wrapper .badge-new { background: var(--usa-green); color: #fff; }
  .usa-wrapper .badge-popular { background: var(--usa-accent); color: #fff; }
  .usa-wrapper .product-card-body {
    padding: 28px;
  }
  .usa-wrapper .product-card-body h3 {
    font-family: var(--usa-font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--usa-text-light);
    margin-bottom: 8px;
  }
  .usa-wrapper .product-card-body .product-tagline {
    color: var(--usa-text-muted-light);
    font-size: 0.88rem;
    font-style: italic;
    margin-bottom: 16px;
  }
  .usa-wrapper .product-card-price {
    font-family: var(--usa-font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--usa-accent);
    margin-bottom: 6px;
  }
  .usa-wrapper .product-card-meta {
    color: var(--usa-text-muted-light);
    font-size: 0.8rem;
    margin-bottom: 20px;
  }
  .usa-wrapper .product-card .btn-primary {
    width: 100%;
    font-size: 0.72rem;
    padding: 14px 20px;
  }

  /* ── CERTIFICATIONS ── */
  .usa-wrapper .cert-section {
    padding: 80px 0;
    background: var(--usa-bg-cream);
    text-align: center;
  }
  .usa-wrapper .cert-headline {
    font-family: var(--usa-font-body);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--usa-text-dark);
    margin-bottom: 48px;
    font-style: italic;
  }
  .usa-wrapper .cert-logos-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .usa-wrapper .cert-logo-item {
    flex: 1;
    max-width: 180px;
    text-align: center;
    padding: 24px 20px;
    border-right: 1px solid var(--usa-border-light);
    transition: all 0.3s;
  }
  .usa-wrapper .cert-logo-item:last-child { border-right: none; }
  .usa-wrapper .cert-logo-item:hover { transform: translateY(-3px); }
  .usa-wrapper .cert-logo-icon {
    font-size: 2rem;
    color: var(--usa-text-dark);
    margin-bottom: 12px;
    display: block;
  }
  .usa-wrapper .cert-logo-item span {
    font-family: var(--usa-font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--usa-text-dark);
    letter-spacing: 1px;
  }
  .usa-wrapper .cert-verified {
    font-family: var(--usa-font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--usa-text-muted-dark);
    position: relative;
    display: inline-block;
    padding: 0 24px;
  }
  .usa-wrapper .cert-verified::before,
  .usa-wrapper .cert-verified::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 80px;
    height: 1px;
    background: var(--usa-border-light);
  }
  .usa-wrapper .cert-verified::before { right: 100%; }
  .usa-wrapper .cert-verified::after { left: 100%; }

  /* ── WHY USA SUPPLEMENT ── */
  .usa-wrapper .why-section {
    padding: 120px 0;
    background: var(--usa-bg-dark);
  }
  .usa-wrapper .why-section .section-head h2 { color: var(--usa-text-light); }
  .usa-wrapper .why-section .section-head p { color: var(--usa-text-muted-light); }
  .usa-wrapper .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .usa-wrapper .why-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--usa-border-dark);
    border-radius: 16px;
    padding: 40px 24px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .usa-wrapper .why-card:hover {
    transform: translateY(-6px);
    border-color: rgba(200,134,10,0.25);
    box-shadow: 0 16px 48px rgba(200,134,10,0.08);
  }
  .usa-wrapper .why-card-icon {
    width: 72px; height: 72px;
    border-radius: 50%;
    border: 2px solid var(--usa-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    font-size: 1.5rem;
    color: var(--usa-accent);
    transition: all 0.3s;
  }
  .usa-wrapper .why-card:hover .why-card-icon {
    background: var(--usa-accent);
    color: #fff;
    transform: scale(1.1);
  }
  .usa-wrapper .why-card h4 {
    font-family: var(--usa-font-display);
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--usa-text-light);
    margin-bottom: 10px;
  }
  .usa-wrapper .why-card p {
    color: var(--usa-text-muted-light);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* ── INGREDIENT TRANSPARENCY ── */
  .usa-wrapper .ingredient-section {
    padding: 120px 0;
    background: var(--usa-bg-cream);
  }
  .usa-wrapper .ingredient-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .usa-wrapper .ingredient-visual {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
  }
  .usa-wrapper .ingredient-visual img {
    width: 100%;
    border-radius: 24px;
  }
  .usa-wrapper .ingredient-info .section-tag { margin-bottom: 12px; }
  .usa-wrapper .ingredient-info h2 {
    font-family: var(--usa-font-display);
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: var(--usa-text-dark);
    margin-bottom: 16px;
  }
  .usa-wrapper .ingredient-info > p {
    color: var(--usa-text-muted-dark);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 36px;
  }
  .usa-wrapper .dosage-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .usa-wrapper .dosage-item {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--usa-card-light);
    border: 1px solid var(--usa-border-light);
    border-radius: 14px;
    padding: 20px 24px;
    transition: all 0.3s;
  }
  .usa-wrapper .dosage-item:hover {
    border-color: rgba(200,134,10,0.25);
    transform: translateX(4px);
  }
  .usa-wrapper .dosage-pill {
    font-family: var(--usa-font-display);
    font-size: 0.85rem;
    font-weight: 800;
    color: #fff;
    background: var(--usa-accent);
    padding: 8px 18px;
    border-radius: 8px;
    white-space: nowrap;
    min-width: 70px;
    text-align: center;
  }
  .usa-wrapper .dosage-text h4 {
    font-family: var(--usa-font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--usa-text-dark);
    margin-bottom: 2px;
  }
  .usa-wrapper .dosage-text span {
    color: var(--usa-text-muted-dark);
    font-size: 0.85rem;
  }

  /* ── FLAVORS ── */
  .usa-wrapper .flavors-section {
    padding: 120px 0;
    background: var(--usa-bg-cream-alt);
  }
  .usa-wrapper .flavors-section .section-head p { color: var(--usa-text-muted-dark); }
  .usa-wrapper .flavor-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .usa-wrapper .flavor-card {
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    cursor: pointer;
