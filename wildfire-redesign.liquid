<!-- ════════════════════════════════════════════════════════════════
     JAVASCRIPT — GSAP + INTERACTIONS
     ════════════════════════════════════════════════════════════════ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const wrapper = document.querySelector('#usa-section-{{ section.id }}');
  if (!wrapper) return;

  // GSAP handles scroll reveal animations to prevent CSS conflicts

  // ═══ ANIMATED COUNTERS ═══
  const counters = wrapper.querySelectorAll('.stat-number[data-target]');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target;
      const target = parseInt(el.dataset.target);
      const suffix = el.dataset.suffix || '';
      if (target === 0 || isNaN(target)) { counterObserver.unobserve(el); return; }
      let current = 0;
      const step = Math.max(1, Math.floor(target / 60));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) { current = target; clearInterval(timer); }
        el.textContent = current + suffix;
      }, 25);
      counterObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => counterObserver.observe(c));

  // ═══ FAQ ACCORDION ═══
  wrapper.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const wasOpen = item.classList.contains('open');
      wrapper.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    });
  });

  // ═══ NEWSLETTER FORM ═══
  const form = wrapper.querySelector('[id^="newsletter-form"]');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      if (input) {
        input.value = '';
        input.placeholder = '✓ Subscribed! Welcome to the community.';
        setTimeout(() => { input.placeholder = 'Enter your email address'; }, 3000);
      }
    });
  }

  // ═══ GSAP SCROLL ANIMATIONS ═══
  function initGSAP() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(initGSAP, 150);
      return;
    }
    gsap.registerPlugin(ScrollTrigger);

    // Generic reveal-up elements (that aren't staggered specific elements)
    gsap.utils.toArray(wrapper.querySelectorAll('.reveal-up:not(.vm-card, .pillar-tile, .product-card, .cert-logo-item, .why-card, .dosage-item, .flavor-card, .stat-card, .review-card, .faq-item)')).forEach(el => {
      gsap.fromTo(el, 
        { opacity: 0, y: 30, filter: 'blur(8px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.2, ease: 'expo.out', scrollTrigger: { trigger: el, start: 'top 85%', once: true } }
      );
    });

    // Hero entrance
    const heroContent = wrapper.querySelector('.hero-content');
    if (heroContent) {
      gsap.fromTo(heroContent.children, 
        { opacity: 0, y: 40, filter: 'blur(10px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.2, duration: 1.5, ease: 'expo.out', delay: 0.1 }
      );
      
      // Hero Parallax
      gsap.to(wrapper.querySelector('.hero-bg'), {
        yPercent: 30,
        ease: 'none',
        scrollTrigger: { trigger: wrapper.querySelector('.hero-section'), start: 'top top', end: 'bottom top', scrub: true }
      });
    }

    // Vision & Mission cards
    if (wrapper.querySelectorAll('.vm-card').length) {
      gsap.fromTo(wrapper.querySelectorAll('.vm-card'), 
        { opacity: 0, y: 40, filter: 'blur(8px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.2, duration: 1.2, ease: 'expo.out', scrollTrigger: { trigger: wrapper.querySelector('.vision-section'), start: 'top 85%', once: true } }
      );
    }

    // Pillar tiles
    if (wrapper.querySelectorAll('.pillar-tile').length) {
      gsap.fromTo(wrapper.querySelectorAll('.pillar-tile'), 
        { opacity: 0, scale: 0.9, filter: 'blur(5px)' },
        { opacity: 1, scale: 1, filter: 'blur(0px)', stagger: 0.1, duration: 1, ease: 'expo.out', scrollTrigger: { trigger: wrapper.querySelector('.pillars-grid'), start: 'top 85%', once: true } }
      );
    }

    // Product cards
    if (wrapper.querySelectorAll('.product-card').length) {
      gsap.fromTo(wrapper.querySelectorAll('.product-card'), 
        { opacity: 0, y: 40, filter: 'blur(8px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.15, duration: 1.2, ease: 'expo.out', scrollTrigger: { trigger: wrapper.querySelector('.products-section'), start: 'top 80%', once: true } }
      );
    }

    // Cert logos
    if (wrapper.querySelectorAll('.cert-logo-item').length) {
      gsap.fromTo(wrapper.querySelectorAll('.cert-logo-item'), 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, stagger: 0.1, duration: 1, ease: 'expo.out', scrollTrigger: { trigger: wrapper.querySelector('.cert-section'), start: 'top 85%', once: true } }
      );
    }

    // Why cards
    if (wrapper.querySelectorAll('.why-card').length) {
      gsap.fromTo(wrapper.querySelectorAll('.why-card'), 
        { opacity: 0, y: 30, filter: 'blur(8px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.15, duration: 1.2, ease: 'expo.out', scrollTrigger: { trigger: wrapper.querySelector('.why-section'), start: 'top 85%', once: true } }
      );
    }

    // Dosage items
      { opacity: 1, x: 0, stagger: 0.12, duration: 0.6, scrollTrigger: { trigger: wrapper.querySelector('.ingredient-section'), start: 'top 75%', once: true } }
    );

    // Flavor cards
    gsap.fromTo(wrapper.querySelectorAll('.flavor-card'), 
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, stagger: 0.12, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: wrapper.querySelector('.flavors-section'), start: 'top 85%', once: true } }
    );

    // Stats
    gsap.fromTo(wrapper.querySelectorAll('.stat-card'), 
      { opacity: 0, scale: 0.8 },
      { opacity: 1, scale: 1, stagger: 0.1, duration: 0.7, ease: 'back.out(1.5)', scrollTrigger: { trigger: wrapper.querySelector('.stats-grid'), start: 'top 85%', once: true } }
    );

    // Review cards
    gsap.fromTo(wrapper.querySelectorAll('.review-card'), 
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, stagger: 0.12, duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: wrapper.querySelector('.reviews-section'), start: 'top 85%', once: true } }
    );

    // Roadmap cards staggered reveal
    if (wrapper.querySelectorAll('.roadmap-card').length) {
      gsap.fromTo(wrapper.querySelectorAll('.roadmap-card'), 
        { opacity: 0, y: 30, filter: 'blur(5px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.08, duration: 0.8, ease: 'power2.out', scrollTrigger: { trigger: wrapper.querySelector('.roadmap-section'), start: 'top 80%', once: true } }
      );
    }

    // FAQ items
    gsap.fromTo(wrapper.querySelectorAll('.faq-item'), 
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, stagger: 0.08, duration: 0.5, scrollTrigger: { trigger: wrapper.querySelector('.faq-section'), start: 'top 80%', once: true } }
    );
  }

  setTimeout(initGSAP, 300);

  // ═══ CURSOR SPOTLIGHT TRACKING ═══
  const handleMouseMove = (e) => {
    const selector = '.spotlight-card, .vm-card, .pillar-tile, .product-card, .why-card, .stat-card, .roadmap-card';
    const cardsToGlow = wrapper.querySelectorAll(selector);
    cardsToGlow.forEach(card => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    });
  };
  document.addEventListener('mousemove', handleMouseMove);

  // ═══ INTERACTIVE ROADMAP CONTROLLER ═══
  const roadmapWrapper = wrapper.querySelector('.roadmap-scroll-wrapper');
  const roadmapPrevBtn = wrapper.querySelector('.roadmap-section .btn-prev');
  const roadmapNextBtn = wrapper.querySelector('.roadmap-section .btn-next');
  const roadmapNavBtns = wrapper.querySelectorAll('.roadmap-nav-btn');
  const roadmapCards = wrapper.querySelectorAll('.roadmap-card');

  if (roadmapWrapper && roadmapPrevBtn && roadmapNextBtn) {
    const scrollAmount = 364; // card width (340) + gap (24)
    roadmapPrevBtn.addEventListener('click', () => {
      roadmapWrapper.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    roadmapNextBtn.addEventListener('click', () => {
      roadmapWrapper.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }

  if (roadmapNavBtns.length > 0 && roadmapCards.length > 0 && typeof gsap !== 'undefined') {
    roadmapNavBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        roadmapNavBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const selectedYear = btn.dataset.year;

        roadmapCards.forEach(card => {
          const cardYear = card.dataset.year;
          if (selectedYear === 'all' || cardYear === selectedYear) {
            gsap.to(card, { 
              display: 'flex', 
              opacity: 1, 
              scale: 1, 
              duration: 0.4, 
              ease: 'power2.out',
              clearProps: 'transform' // Avoid overriding hover styles
            });
          } else {
            gsap.to(card, { 
              display: 'none', 
              opacity: 0, 
              scale: 0.95, 
              duration: 0.3, 
              ease: 'power2.in' 
            });
          }
        });
      });
    });
  }

});
</script>


