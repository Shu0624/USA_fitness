  .usa-wrapper .footer-col h4 {
    font-family: var(--usa-font-display);
    font-size: 0.82rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--usa-text-light);
  }
  .usa-wrapper .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .usa-wrapper .footer-col a {
    color: var(--usa-text-muted-light);
    font-size: 0.9rem;
    transition: color 0.3s;
  }
  .usa-wrapper .footer-col a:hover { color: var(--usa-accent); }
  .usa-wrapper .footer-compliance {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .usa-wrapper .footer-compliance span {
    font-size: 0.72rem;
    color: var(--usa-text-muted-light);
    padding: 6px 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--usa-border-dark);
    border-radius: 6px;
  }
  .usa-wrapper .footer-bar {
    text-align: center;
    color: var(--usa-text-muted-light);
    font-size: 0.82rem;
  }

  /* ════════════════════════════════════════════════
     RESPONSIVE
     ════════════════════════════════════════════════ */
  @media (max-width: 992px) {
    .usa-wrapper .vm-grid,
    .usa-wrapper .ingredient-layout,
    .usa-wrapper .community-grid,
    .usa-wrapper .newsletter-inner { grid-template-columns: 1fr; gap: 40px; }
    .usa-wrapper .pillars-grid { grid-template-columns: repeat(3, 1fr); }
    .usa-wrapper .products-grid,
    .usa-wrapper .flavor-grid,
    .usa-wrapper .reviews-grid { grid-template-columns: 1fr; gap: 20px; }
    .usa-wrapper .why-grid { grid-template-columns: 1fr 1fr; }
    .usa-wrapper .cert-logos-row { gap: 16px; }
    .usa-wrapper .cert-logo-item { border-right: none; }
    .usa-wrapper .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .usa-wrapper .hero-content { margin-left: 0; }
    .usa-wrapper .newsletter-inner { padding: 40px 28px; }
  }
  @media (max-width: 600px) {
    .usa-wrapper .hero-section h1 { font-size: 2.4rem; letter-spacing: -1px; }
    .usa-wrapper .hero-content { padding: 0 20px; }
    .usa-wrapper .section-head h2 { font-size: 2rem; }
    .usa-wrapper .pillars-grid { grid-template-columns: 1fr 1fr; }
    .usa-wrapper .why-grid { grid-template-columns: 1fr; }
    .usa-wrapper .input-group { flex-direction: column; }
    .usa-wrapper .footer-grid { grid-template-columns: 1fr; }
    .usa-wrapper .stats-grid { grid-template-columns: 1fr; }
    .usa-wrapper .community-text h2 { font-size: 2rem; }
    .usa-wrapper .ingredient-info h2 { font-size: 2rem; }
    .usa-wrapper .vm-card { padding: 32px 24px; }
    .usa-wrapper .flavor-card { min-height: 360px; }
  }

{%- endstyle -%}


