<!-- sections/vision-mission.liquid -->
<section class="vision-section" id="vision">
  <div class="container">
    <div class="section-head reveal-up">
      {%- if section.settings.tag != blank -%}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="vm-grid">
      <!-- Card 1: Vision -->
      <div class="vm-card reveal-up">
        <div class="vm-card-glow"></div>
        <div class="vm-icon"><i class="fa-solid {{ section.settings.vision_icon | default: 'fa-eye' }}"></i></div>
        <h3>{{ section.settings.vision_title | default: 'Our Vision' }}</h3>
        <p>{{ section.settings.vision_text }}</p>
        
        {%- assign vision_stats = section.blocks | where: "type", "vision_stat" -%}
        {%- if vision_stats.size > 0 -%}
          <div class="vm-stats-row">
            {%- for block in vision_stats -%}
              <div class="vm-stat" {{ block.shopify_attributes }}>
                <span class="stat-number vm-stat-number" data-target="{{ block.settings.target_number }}" data-suffix="{{ block.settings.suffix }}">{{ block.settings.fallback_text }}</span>
                <span class="vm-stat-label">{{ block.settings.label }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Card 2: Mission -->
      <div class="vm-card reveal-up">
        <div class="vm-card-glow"></div>
        <div class="vm-icon"><i class="fa-solid {{ section.settings.mission_icon | default: 'fa-bullseye' }}"></i></div>
        <h3>{{ section.settings.mission_title | default: 'Our Mission' }}</h3>
        <p>{{ section.settings.mission_text }}</p>
        
        {%- assign mission_features = section.blocks | where: "type", "mission_feature" -%}
        {%- if mission_features.size > 0 -%}
          <div class="vm-pillars-row">
            {%- for block in mission_features -%}
              <div class="vm-pillar-chip" {{ block.shopify_attributes }}>
                <i class="fa-solid {{ block.settings.icon_class | default: 'fa-flask' }}"></i> {{ block.settings.label }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vision & Mission",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Our Purpose"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Driven by Science. Built for Everyone."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subtitle",
      "default": "Two pillars that guide everything we build, create, and deliver."
    },
    {
      "type": "header",
      "content": "🔭 Vision Card"
    },
    {
      "type": "text",
      "id": "vision_icon",
      "label": "Vision Icon Class",
      "default": "fa-eye"
    },
    {
      "type": "text",
      "id": "vision_title",
      "label": "Vision Title",
      "default": "Our Vision"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Vision Text",
      "default": "To build the world's most trusted health ecosystem integrating nutrition, wellness, education, community, technology and preventive health."
    },
    {
      "type": "header",
      "content": "🎯 Mission Card"
    },
    {
      "type": "text",
      "id": "mission_icon",
      "label": "Mission Icon Class",
      "default": "fa-bullseye"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Mission Title",
      "default": "Our Mission"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Make science-backed health solutions accessible to every individual through products, education, technology and community."
    }
  ],
  "blocks": [
    {
      "type": "vision_stat",
      "name": "Vision Stat Counter",
      "settings": [
        {
          "type": "text",
          "id": "target_number",
          "label": "Target Number (for animation)",
          "default": "100"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g. +, B+, %)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "fallback_text",
          "label": "Fallback Text",
          "default": "0"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stat Label",
          "default": "Countries"
        }
      ]
    },
    {
      "type": "mission_feature",
      "name": "Mission Pillar Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon_class",
          "label": "Icon Class",
          "default": "fa-flask"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Pillar Label",
          "default": "Nutrition"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vision & Mission",
      "blocks": [
        { "type": "vision_stat", "settings": { "target_number": "1", "suffix": "B+", "label": "Lives Impacted" } },
        { "type": "vision_stat", "settings": { "target_number": "100", "suffix": "+", "label": "Countries" } },
        { "type": "vision_stat", "settings": { "target_number": "0", "suffix": "24/7", "fallback_text": "24/7", "label": "Science Driven" } },
        { "type": "mission_feature", "settings": { "icon_class": "fa-flask", "label": "Nutrition" } },
        { "type": "mission_feature", "settings": { "icon_class": "fa-graduation-cap", "label": "Education" } },
        { "type": "mission_feature", "settings": { "icon_class": "fa-microchip", "label": "Technology" } },
        { "type": "mission_feature", "settings": { "icon_class": "fa-people-group", "label": "Community" } }
      ]
    }
  ]
}
{% endschema %}
