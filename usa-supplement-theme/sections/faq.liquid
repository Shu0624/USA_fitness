<!-- sections/faq.liquid -->
<section class="faq-section" id="faq">
  <div class="container">
    <div class="section-head reveal-up">
      {%- if section.settings.tag != blank -%}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    
    {%- if section.blocks.size > 0 -%}
      <div class="faq-list">
        {%- for block in section.blocks -%}
          <div class="faq-item reveal-up" {{ block.shopify_attributes }}>
            <button class="faq-q"><span>{{ block.settings.question }}</span><i class="fa-solid fa-plus"></i></button>
            <div class="faq-a"><p>{{ block.settings.answer }}</p></div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is USA Supplement's vision?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "USA Supplement is building the world's most trusted health ecosystem integrating nutrition, wellness, education, community, technology and preventive health."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What causes the tingling sensation after taking Wildfire?", "answer": "The tingling (paresthesia) is caused by the clinical dose of Beta-Alanine (5g). It is completely harmless and indicates active binding to nerve receptors for carnosine loading." } },
        { "type": "faq_item", "settings": { "question": "Is Wildfire safe for drug-tested competitive athletes?", "answer": "Yes. Wildfire is Informed Choice certified and Labdoor verified. Every batch is tested for 250+ WADA banned substances, ensuring complete safety for competition." } },
        { "type": "faq_item", "settings": { "question": "How should I consume Wildfire Pre-Workout?", "answer": "Mix 1 scoop with 200–250 ml of cold water, 20–30 minutes before training. Start with half a scoop if you are caffeine-sensitive." } }
      ]
    }
  ]
}
{% endschema %}
