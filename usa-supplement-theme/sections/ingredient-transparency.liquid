<!-- sections/ingredient-transparency.liquid -->
<section class="ingredient-section" id="ingredients">
  <div class="container">
    <div class="ingredient-layout">
      <div class="ingredient-visual reveal-up">
        {%- if section.settings.showcase_img != blank -%}
          <img src="{{ section.settings.showcase_img | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}">
        {%- else -%}
          <img src="{{ 'Untitled_design_1.png' | asset_url }}" alt="Enhanced Focus & Mental Alertness">
        {%- endif -%}
      </div>
      
      <div class="ingredient-info reveal-up">
        {%- if section.settings.tag != blank -%}
          <div class="section-tag">{{ section.settings.tag }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
        
        {%- if section.blocks.size > 0 -%}
          <div class="dosage-list">
            {%- for block in section.blocks -%}
              <div class="dosage-item" {{ block.shopify_attributes }}>
                <span class="dosage-pill">{{ block.settings.dosage }}</span>
                <div class="dosage-text">
                  <h4>{{ block.settings.title }}</h4>
                  <span>{{ block.settings.description }}</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredient Transparency",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Ingredient Transparency"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Every dose, on the label."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subtitle",
      "default": "No under-dosed fillers. No hidden blends. Every ingredient, every milligram right there on the tub."
    },
    {
      "type": "image_picker",
      "id": "showcase_img",
      "label": "Showcase Image"
    }
  ],
  "blocks": [
    {
      "type": "dosage_item",
      "name": "Dosage Item",
      "settings": [
        {
          "type": "text",
          "id": "dosage",
          "label": "Dosage (e.g. 5g)",
          "default": "5g"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Name",
          "default": "Beta-Alanine"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "clinically proven endurance dose"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Transparency",
      "blocks": [
        { "type": "dosage_item", "settings": { "dosage": "5g", "title": "Beta-Alanine", "description": "clinically proven endurance dose" } },
        { "type": "dosage_item", "settings": { "dosage": "2.5g", "title": "L-Citrulline DL-Malate", "description": "for pump and blood flow" } },
        { "type": "dosage_item", "settings": { "dosage": "200mg", "title": "Caffeine Anhydrous", "description": "clean energy without the crash" } },
        { "type": "dosage_item", "settings": { "dosage": "180mg", "title": "Choline Bitartrate", "description": "focus and mind-muscle connection" } }
      ]
    }
  ]
}
{% endschema %}
