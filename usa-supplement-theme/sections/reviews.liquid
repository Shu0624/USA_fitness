<!-- sections/reviews.liquid -->
<section class="reviews-section" id="reviews">
  <div class="container">
    <div class="section-head reveal-up">
      {%- if section.settings.tag != blank -%}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="reviews-grid">
        {%- for block in section.blocks -%}
          <div class="review-card {% if block.settings.featured %}featured{% endif %} reveal-up" {{ block.shopify_attributes }}>
            <div class="review-stars">
              {%- assign stars = block.settings.stars | default: 5 -%}
              {%- for i in (1..stars) -%}★{%- endfor -%}
            </div>
            
            <p class="review-text">"{{ block.settings.text }}"</p>
            
            <div class="review-author">
              {%- if block.settings.avatar_img != blank -%}
                <img class="review-avatar" src="{{ block.settings.avatar_img | image_url: width: 100 }}" alt="{{ block.settings.name }}" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover;">
              {%- else -%}
                <div class="review-avatar" style="background: {{ block.settings.avatar_gradient | default: 'linear-gradient(135deg, #F09E43, #E08C32)' }};">
                  {{ block.settings.name | slice: 0, 1 | upcase }}
                </div>
              {%- endif -%}
              <div>
                <h4>{{ block.settings.name }}</h4>
                <span>{{ block.settings.role }}</span>
              </div>
            </div>
            <span class="review-badge"><i class="fa-solid fa-circle-check"></i> Verified Purchase</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Trusted by Athletes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Our Community Says"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subtitle",
      "default": "Real reviews from real athletes who chose science over shortcuts."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Wildfire is the cleanest pre-workout I've ever used. No jitters, no crash — just pure, sustained energy."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer Name",
          "default": "Rahul Sharma"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Reviewer Role / Location",
          "default": "Competitive Powerlifter · Hyderabad"
        },
        {
          "type": "image_picker",
          "id": "avatar_img",
          "label": "Reviewer Avatar Image"
        },
        {
          "type": "text",
          "id": "avatar_gradient",
          "label": "Avatar Gradient CSS (Fallback)",
          "default": "linear-gradient(135deg, #F09E43, #E08C32)"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured (Highlight card style)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        { "type": "review", "settings": { "text": "Wildfire is the cleanest pre-workout I've ever used. No jitters, no crash — just pure, sustained energy through my entire 90-minute session.", "name": "Rahul Sharma", "role": "Competitive Powerlifter · Hyderabad" } },
        { "type": "review", "settings": { "text": "As a drug-tested athlete, I can't risk contamination. USA Supplement's Informed Choice certification gives me 100% confidence. The focus is unreal.", "name": "Priya Nair", "role": "National Level Swimmer · Chennai", "featured": true, "avatar_gradient": "linear-gradient(135deg, #6366f1, #8b5cf6)" } },
        { "type": "review", "settings": { "text": "I've tried every brand on the market. Nothing comes close to the pump and endurance I get from Wildfire. My clients are now hooked too.", "name": "Vikram Patel", "role": "Certified Personal Trainer · Mumbai", "avatar_gradient": "linear-gradient(135deg, #22c55e, #16a34a)" } }
      ]
    }
  ]
}
{% endschema %}
