<!-- sections/product-grid.liquid -->
<section class="products-section" id="products">
  <div class="container">
    <div class="section-head reveal-up">
      {%- if section.settings.tag != blank -%}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign featured_collection = collections[section.settings.featured_collection] -%}
    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div class="products-grid">
        {%- for product in featured_collection.products limit: section.settings.limit -%}
          {% render 'product-card-item', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="products-grid">
        {%- for i in (1..3) -%}
          <div class="product-card reveal-up">
            <div class="product-card-img" style="background: var(--usa-bg-cream); height: 320px; display: flex; align-items: center; justify-content: center;">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' | replace: '<svg', '<svg style="width: 60%; height: auto; opacity: 0.15;"' }}
            </div>
            <div class="product-card-body">
              <h3>Sample Product {{ i }}</h3>
              <p class="product-tagline">Example supplement tagline</p>
              <div class="product-card-price">Rs. 2,499</div>
              <p class="product-card-meta">30 servings per tub</p>
              <a href="#" class="btn btn-primary" style="display:inline-block; text-decoration:none; margin-top:12px; width:100%; text-align:center;">View Product →</a>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Science-Backed Nutrition"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subtitle",
      "default": "Premium supplements formulated for real results. No shortcuts, no compromises."
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Product Limit",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
