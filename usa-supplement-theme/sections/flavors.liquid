<!-- sections/flavors.liquid -->
<section class="flavors-section" id="flavors">
  <div class="container">
    <div class="section-head reveal-up">
      {%- if section.settings.tag != blank -%}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="flavor-grid">
        {%- for block in section.blocks -%}
          <div class="flavor-card" style="background: linear-gradient(180deg, {{ block.settings.color }}cc 0%, {{ block.settings.color }} 100%);" {{ block.shopify_attributes }}>
            {%- if block.settings.badge != blank -%}
              <span class="flavor-card-badge">{{ block.settings.badge | upcase }}</span>
            {%- endif -%}
            
            <div class="flavor-card-content">
              <h3>{{ block.settings.title }}</h3>
              <span class="flavor-desc">{{ block.settings.description }}</span>
            </div>
            
            <a href="{{ block.settings.link | default: '#products' }}" class="flavor-arrow" aria-label="Go to flavor product page">
              <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="flavors-cta reveal-up">
        <a href="{{ section.settings.cta_url | default: '#products' }}" class="btn btn-primary">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Flavor Grid",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "6 Flavors"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Find your flavor."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subtitle",
      "default": "Same clinical formula. Six ways to crave it."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Link Text",
      "default": "Shop All Flavors →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link URL"
    }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Flavor Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Flavor Name",
          "default": "Kiwi Krazze"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short Description",
          "default": "Tropical & tart"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Card Base Color",
          "default": "#5ba829"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (leave blank for none)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Redirect Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flavor Grid",
      "blocks": [
        { "type": "flavor", "settings": { "title": "Kiwi Krazze", "description": "Tropical & tart", "color": "#5ba829" } },
        { "type": "flavor", "settings": { "title": "Punch Rush", "description": "Fruit punch blast", "color": "#c44040", "badge": "POPULAR" } },
        { "type": "flavor", "settings": { "title": "Citrus Storm", "description": "Sweet orange", "color": "#d48a1a" } }
      ]
    }
  ]
}
{% endschema %}
