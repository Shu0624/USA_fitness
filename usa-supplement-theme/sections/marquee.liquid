<!-- sections/marquee.liquid -->
{%- if section.blocks.size > 0 -%}
  <div class="marquee-bar" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
    <div class="marquee-track">
      {%- for i in (1..3) -%}
        {%- for block in section.blocks -%}
          <span {{ block.shopify_attributes }}>{{ block.settings.text | upcase }}</span>
          <span class="marquee-dot" style="background: {{ section.settings.dot_color }};"></span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Notification",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#aaaaaa"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Bullet Color",
      "default": "#F09E43"
    }
  ],
  "blocks": [
    {
      "type": "notice",
      "name": "Notice Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Notice Text",
          "default": "INFORMED CHOICE CERTIFIED"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Notification",
      "blocks": [
        { "type": "notice", "settings": { "text": "FREE SHIPPING ABOVE ₹999" } },
        { "type": "notice", "settings": { "text": "INFORMED CHOICE CERTIFIED" } },
        { "type": "notice", "settings": { "text": "BANNED-SUBSTANCE FREE" } },
        { "type": "notice", "settings": { "text": "LAB-TESTED & VERIFIED" } },
        { "type": "notice", "settings": { "text": "SCIENCE-BACKED SOLUTIONS" } }
      ]
    }
  ]
}
{% endschema %}
