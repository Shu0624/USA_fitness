{%- comment -%}
  Social Icons Snippet
  Usage: {% render 'social-icons' %}
  Pulls URLs from global theme settings.
{%- endcomment -%}

<div class="social-row">
  {%- if settings.social_instagram != blank -%}
    <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener"><i class="fa-brands fa-instagram"></i></a>
  {%- endif -%}
  {%- if settings.social_facebook != blank -%}
    <a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener"><i class="fa-brands fa-facebook-f"></i></a>
  {%- endif -%}
  {%- if settings.social_youtube != blank -%}
    <a href="{{ settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener"><i class="fa-brands fa-youtube"></i></a>
  {%- endif -%}
  {%- if settings.social_twitter != blank -%}
    <a href="{{ settings.social_twitter }}" aria-label="Twitter" target="_blank" rel="noopener"><i class="fa-brands fa-x-twitter"></i></a>
  {%- endif -%}
</div>
