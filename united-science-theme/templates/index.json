        "r1": { "type": "review", "settings": { "rating": 5, "review_text": "Wildfire is the cleanest pre-workout I've ever used. No jitters, no crash — just pure, sustained energy through my entire 90-minute session.", "reviewer_name": "Rahul Sharma", "reviewer_role": "Competitive Powerlifter · Hyderabad", "avatar_color_1": "#c8860a", "avatar_color_2": "#e0a832" } },
        "r2": { "type": "review", "settings": { "rating": 5, "review_text": "As a drug-tested athlete, I can't risk contamination. USA Supplement's Informed Choice certification gives me 100% confidence. The focus is unreal.", "reviewer_name": "Priya Nair", "reviewer_role": "National Level Swimmer · Chennai", "is_featured": true, "avatar_color_1": "#6366f1", "avatar_color_2": "#8b5cf6" } },
        "r3": { "type": "review", "settings": { "rating": 5, "review_text": "I've tried every brand on the market. Nothing comes close to the pump and endurance I get from Wildfire. My clients are now hooked too.", "reviewer_name": "Vikram Patel", "reviewer_role": "Certified Personal Trainer · Mumbai", "avatar_color_1": "#22c55e", "avatar_color_2": "#16a34a" } }
