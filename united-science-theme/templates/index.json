      "blocks": {
        "q1": { "type": "faq_item", "settings": { "question": "What is USA Supplement's vision?", "answer": "<p>USA Supplement is building the world's most trusted health ecosystem integrating nutrition, wellness, education, community, technology and preventive health.</p>" } },
        "q2": { "type": "faq_item", "settings": { "question": "What causes the tingling sensation after taking Wildfire?", "answer": "<p>The tingling sensation is caused by Beta-Alanine, a clinically studied amino acid that helps buffer lactic acid in muscles. It is completely harmless and temporary.</p>" } },
        "q3": { "type": "faq_item", "settings": { "question": "Is Wildfire safe for drug-tested competitive athletes?", "answer": "<p>Yes, Wildfire is 100% banned-substance free and certified by Informed Choice. Every batch undergoes rigorous testing to ensure zero contamination.</p>" } },
        "q4": { "type": "faq_item", "settings": { "question": "How should I consume Wildfire Pre-Workout?", "answer": "<p>Mix 1 scoop with 250-300ml of cold water and consume 15-30 minutes before your workout. If you are sensitive to caffeine, start with a half scoop to assess tolerance.</p>" } },
        "q5": { "type": "faq_item", "settings": { "question": "What other products does USA Supplement offer?", "answer": "<p>Currently we offer Wildfire Pre-Workout, USA Plant Protein, and USA Fermented Yeast Protein. We are expanding our line with more science-backed formulas soon.</p>" } },
        "q6": { "type": "faq_item", "settings": { "question": "Can I stack Wildfire with other supplements?", "answer": "<p>Yes, you can stack it with non-stimulant supplements like Creatine or L-Glutamine. Avoid stacking it with other high-stimulant products.</p>" } }
