{%- comment -%}
  Flavor Showcase — Each flavor is a block with custom bg color
{%- endcomment -%}

<section class="flavors-section" id="flavors">
  <div class="container">
    {% render 'section-header', tag: section.settings.tag, heading: section.settings.heading, subheading: section.settings.subheading %}

    {%- if section.blocks.size > 0 -%}
      <div class="flavor-grid">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.url | default: '#' }}" class="flavor-card" style="background: linear-gradient(180deg, {{ block.settings.bg_color }}cc 0%, {{ block.settings.bg_color }} 100%);" {{ block.shopify_attributes }}>
            {%- if block.settings.badge != blank -%}
              <span class="flavor-card-badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            <div class="flavor-card-content">
              <h3>{{ block.settings.name }}</h3>
              <span class="flavor-desc">{{ block.settings.description }}</span>
            </div>
            <div class="flavor-arrow"><i class="fa-solid fa-arrow-right"></i></div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="flavors-cta reveal-up">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-primary">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Flavor Showcase",
  "class": "flavors-wrapper",
  "settings": [
    { "type": "text", "id": "tag", "label": "Section Tag", "default": "6 Flavors" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your flavor." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Same clinical formula. Six ways to crave it." },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Shop All Flavors →" },
    { "type": "url", "id": "cta_url", "label": "CTA Button Link" }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Flavor Card",
      "settings": [
        { "type": "text", "id": "name", "label": "Flavor Name", "default": "Kiwi Krazze" },
        { "type": "text", "id": "description", "label": "Short Description", "default": "Tropical & tart" },
        { "type": "color", "id": "bg_color", "label": "Card Background Color", "default": "#5ba829" },
        { "type": "text", "id": "badge", "label": "Badge Text (optional)" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flavor Showcase",
      "blocks": [
        { "type": "flavor", "settings": { "name": "Kiwi Krazze", "description": "Tropical & tart", "bg_color": "#5ba829" } },
        { "type": "flavor", "settings": { "name": "Punch Rush", "description": "Fruit punch blast", "bg_color": "#c44040", "badge": "POPULAR" } },
        { "type": "flavor", "settings": { "name": "Citrus Storm", "description": "Sweet orange", "bg_color": "#d48a1a" } }
      ]
    }
  ]
}
{% endschema %}
