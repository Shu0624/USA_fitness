{%- comment -%}
  FAQ Accordion — Each question is a block, fully editable
{%- endcomment -%}

<section class="faq-section" id="faq">
  <div class="container">
    {% render 'section-header', tag: section.settings.tag, heading: section.settings.heading, subheading: section.settings.subheading %}

    {%- if section.blocks.size > 0 -%}
      <div class="faq-list">
        {%- for block in section.blocks -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-q">
              <span>{{ block.settings.question }}</span>
              <i class="fa-solid fa-plus"></i>
            </button>
            <div class="faq-a">
              {{ block.settings.answer }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "class": "faq-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is USA Supplement's vision?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>USA Supplement is building the world's most trusted health ecosystem integrating nutrition, wellness, education, community, technology and preventive health.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What is USA Supplement's vision?" } },
        { "type": "faq_item", "settings": { "question": "What causes the tingling sensation after taking Wildfire?" } },
        { "type": "faq_item", "settings": { "question": "Is Wildfire safe for drug-tested competitive athletes?" } },
        { "type": "faq_item", "settings": { "question": "How should I consume Wildfire Pre-Workout?" } },
        { "type": "faq_item", "settings": { "question": "What other products does USA Supplement offer?" } },
        { "type": "faq_item", "settings": { "question": "Can I stack Wildfire with other supplements?" } }
      ]
    }
  ]
}
{% endschema %}
