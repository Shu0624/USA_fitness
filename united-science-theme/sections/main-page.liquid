{%- comment -%}
  Generic Page Section — For About Us, Contact, etc.
{%- endcomment -%}

<section class="page-section">
  <div class="container">
    <div class="page-content reveal-up">
      <h1>{{ page.title }}</h1>
      <div class="page-body">
        {{ page.content }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "class": "page-wrapper",
  "settings": []
}
{% endschema %}
