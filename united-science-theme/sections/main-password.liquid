{%- comment -%} Password Page Section {%- endcomment -%}
<div class="password-main reveal-up">
  <h1 style="font-family: var(--usa-font-display); font-size: 3rem; color: var(--usa-text-dark); margin-bottom: 20px;">Coming Soon</h1>
  <p style="color: var(--usa-text-muted-dark); margin-bottom: 40px;">United Science Alliance is getting ready to launch.</p>
  
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <div style="display: flex; justify-content: center; gap: 10px;">
      <input type="password" name="password" id="Password" placeholder="Store password" style="padding: 12px 20px; border: 1px solid var(--usa-border-dark); border-radius: 8px;">
      <button type="submit" class="btn btn-primary">Enter</button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": []
}
{% endschema %}
