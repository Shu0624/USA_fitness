{%- comment -%}
  404 Not Found Page — Branded error page
{%- endcomment -%}

<section class="page-section error-page">
  <div class="container">
    <div class="error-content reveal-up">
      <div class="error-code">404</div>
      <h1>{{ section.settings.heading | default: 'Page Not Found' }}</h1>
      <p>{{ section.settings.description | default: "The page you're looking for doesn't exist or has been moved." }}</p>
      <a href="{{ routes.root_url }}" class="btn btn-primary">
        {{ section.settings.cta_text | default: 'Back to Homepage' }} <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .error-page { padding: 160px 0 120px; text-align: center; background: var(--usa-bg-cream); }
  .error-code {
    font-family: var(--usa-font-display);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--usa-accent) 0%, var(--usa-accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }
  .error-content h1 {
    font-family: var(--usa-font-display);
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--usa-text-dark);
  }
  .error-content p {
    color: var(--usa-text-muted-dark);
    font-size: 1.05rem;
    margin-bottom: 32px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

{% schema %}
{
  "name": "404 Error",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page Not Found" },
    { "type": "text", "id": "description", "label": "Description", "default": "The page you're looking for doesn't exist or has been moved." },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Back to Homepage" }
  ]
}
{% endschema %}
