{%- comment -%}
  Featured Products — Dynamically pulls from a selected Shopify Collection
  No hardcoded products. Everything from the Shopify admin.
{%- endcomment -%}

<section class="products-section" id="products">
  <div class="container">
    {% render 'section-header', tag: section.settings.tag, heading: section.settings.heading, subheading: section.settings.subheading %}

    {%- if section.settings.collection != blank and collections[section.settings.collection].products.size > 0 -%}
      {%- assign collection = collections[section.settings.collection] -%}
      <div class="products-grid">
        {%- for product in collection.products limit: section.settings.max_products -%}
          {% render 'product-card', product: product, badge_text: product.metafields.custom.badge %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- Mock Products for Design Showcase -->
      <div class="products-grid">
        <!-- Mock Product 1 -->
        <div class="product-card reveal-up">
          <a href="/products/wildfire-pre-workout" class="product-card-img" style="display: block; text-decoration: none;">
            <span class="product-card-badge badge-bestseller">BESTSELLER</span>
            <img src="{{ 'wildfire-preworkout.png' | asset_url }}" alt="Wildfire Pre-Workout" width="400" height="400" loading="lazy">
          </a>
          <div class="product-card-body">
            <h3><a href="/products/wildfire-pre-workout" style="color: inherit; text-decoration: none;">Wildfire Pre-Workout</a></h3>
            <p class="product-tagline">Clinically dosed. Banned-substance free.</p>
            <div class="product-card-price">Rs. 2,499</div>
            <p class="product-card-meta">30 servings per tub</p>
            <a href="/products/wildfire-pre-workout" class="btn btn-primary" style="display:inline-block; text-decoration:none;">View Product →</a>
          </div>
        </div>
        <!-- Mock Product 2 -->
        <div class="product-card reveal-up">
          <a href="/products/usa-plant-protein" class="product-card-img" style="display: block; text-decoration: none;">
            <span class="product-card-badge badge-new">NEW</span>
            <img src="{{ 'Plant protien (4).jpeg' | asset_url }}" alt="USA Plant Protein" width="400" height="400" loading="lazy">
          </a>
          <div class="product-card-body">
            <h3><a href="/products/usa-plant-protein" style="color: inherit; text-decoration: none;">USA Plant Protein</a></h3>
            <p class="product-tagline">Pure plant-powered performance.</p>
            <div class="product-card-price">Rs. 1,999</div>
            <p class="product-card-meta">25 servings per tub</p>
            <a href="/products/usa-plant-protein" class="btn btn-primary" style="display:inline-block; text-decoration:none;">View Product →</a>
          </div>
        </div>
        <!-- Mock Product 3 -->
        <div class="product-card reveal-up">
          <a href="/products/usa-fermented-yeast-protein" class="product-card-img" style="display: block; text-decoration: none;">
            <span class="product-card-badge badge-popular">POPULAR</span>
            <img src="{{ 'fermented yeast protien.jpeg' | asset_url }}" alt="USA Fermented Yeast Protein" width="400" height="400" loading="lazy">
          </a>
          <div class="product-card-body">
            <h3><a href="/products/usa-fermented-yeast-protein" style="color: inherit; text-decoration: none;">USA Fermented Yeast Protein</a></h3>
            <p class="product-tagline">Next-gen fermented protein.</p>
            <div class="product-card-price">Rs. 2,299</div>
            <p class="product-card-meta">30 servings per tub</p>
            <a href="/products/usa-fermented-yeast-protein" class="btn btn-primary" style="display:inline-block; text-decoration:none;">View Product →</a>
          </div>
        </div>
      </div>
      <p style="text-align:center; color: var(--usa-text-muted-dark); margin-top: 25px; font-size: 0.9rem; font-style: italic;">
        (Showing design placeholders. In the Theme Customizer settings on the left, select a collection to display live Shopify products)
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "class": "featured-products-section",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Science-Backed Nutrition"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium supplements formulated for real results. No shortcuts, no compromises."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products to Show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
