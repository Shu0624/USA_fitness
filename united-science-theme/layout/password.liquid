<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} &ndash; Coming Soon</title>
  {{ content_for_header }}
  {{ 'usa-base.css' | asset_url | stylesheet_tag }}
  <style>
    body { background: var(--usa-bg-cream); display: flex; flex-direction: column; min-height: 100vh; align-items: center; justify-content: center; text-align: center; }
    main { padding: 40px; }
  </style>
</head>
<body class="template-password">
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
</body>
</html>
